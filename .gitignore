# ============================================================
# GlobeHacks — root .gitignore
# ============================================================

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
desktop.ini

# ── Large dataset files ──────────────────────────────────────
LabValidation_withVideos/
*.zip
*.mot
*.sto
*.c3d
*.trc
*.osim

# ── Secrets & credentials ────────────────────────────────────
# InsForge project config contains live API keys — never commit
web/.insforge/
.insforge/
*.insforge

# Environment files
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.log

# ── Node / Next.js ───────────────────────────────────────────
node_modules/
.next/
out/
coverage/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel

# hydrawav3-app (legacy — web/ is the canonical app now)
hydrawav3-app/.git/
hydrawav3-app/node_modules/
hydrawav3-app/.next/
hydrawav3-app/next-env.d.ts
hydrawav3-app/*.tsbuildinfo

# ── Editor / IDE ─────────────────────────────────────────────
.cursor/
.vscode/
.idea/
*.swp
*.swo
*~

# ── Secrets / certs ──────────────────────────────────────────
*.pem
*.key
*.p12
secrets/

# InsForge & AI agent skills
.insforge
.agent
.agents
.augment
.claude
.cline
.github/copilot*
.kilocode
.qoder
.qwen
.roo
.trae
.windsurf

# Node / Next.js
node_modules
.next
dist
coverage
tsconfig.tsbuildinfo

# Python caches
__pycache__
*.pyc
